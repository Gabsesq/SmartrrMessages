# Copy to .env for local use only; never commit .env.
# Vercel: Project → Settings → Environment Variables

SMARTRR_ACCESS_TOKEN=

# Optional: every webhook is also POSTed here (second hop).
# FORWARD_URL=

# Supabase (service role for inserts — never expose to browser).
# SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Viewer page GET /api/logs?secret=...
# LOGS_SECRET=

# Optional: GET /api/test-call?secret=...&to=%2B1... — if TWILIO_TEST_CALL_SECRET is set, use it as secret; otherwise use LOGS_SECRET.
# TWILIO_TEST_CALL_SECRET=

# Failed-payment automated call workflow (Twilio).
# Enable only when ready: 1=true, 0/empty=false
# ENABLE_FAILED_PAYMENT_CALLS=0
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15551234567
# Required for failed-payment voice calls: public MP3/WAV URL Twilio <Play>s (no TTS fallback).
# TWILIO_FAILED_PAYMENT_AUDIO_URL=https://example.com/audio/failed-payment.mp3
# Voicemail: default DetectMessageEnd waits for greeting/beep then plays the same audio.
# TWILIO_AMD_MODE=off          — skip AMD (immediate play; poor for voicemail)
# TWILIO_MACHINE_DETECTION_TIMEOUT=45  — optional seconds 3–59 for long greetings
# Optional: extra E.164 numbers (comma-separated) to never call for failed-payment webhooks.
# Built-in blocklist always includes the internal work line; add more here if needed.
# TWILIO_FAILED_PAYMENT_BLOCKLIST=+15551234567,+442071838750
