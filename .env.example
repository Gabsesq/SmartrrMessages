# Copy to .env for local use only; never commit .env.
# Vercel: Project → Settings → Environment Variables

SMARTRR_ACCESS_TOKEN=

# Optional: every webhook is also POSTed here (second hop).
# FORWARD_URL=

# Supabase (service role for inserts — never expose to browser).
# SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Viewer page GET /api/logs?secret=...
# LOGS_SECRET=

# Failed-payment automated call workflow (Twilio).
# Enable only when ready: 1=true, 0/empty=false
# ENABLE_FAILED_PAYMENT_CALLS=0
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15551234567
