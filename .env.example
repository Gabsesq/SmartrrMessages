# Copy to .env for local use only; never commit .env.
# Vercel: Project → Settings → Environment Variables

SMARTRR_ACCESS_TOKEN=

# Optional: every webhook is also POSTed here (second hop).
# FORWARD_URL=

# Supabase (service role for inserts — never expose to browser).
# SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# Viewer page GET /api/logs?secret=...
# LOGS_SECRET=

# Optional: GET /api/test-call?secret=...&to=%2B1... — if TWILIO_TEST_CALL_SECRET is set, use it as secret; otherwise use LOGS_SECRET.
# TWILIO_TEST_CALL_SECRET=
# Optional: default destination for /api/test-call (JSON or ?format=html). Override with &to= in the URL.
# TWILIO_TEST_TO_NUMBER=+15551234567

# Failed-payment automated call workflow (Twilio).
# Enable only when ready: 1=true, 0/empty=false
# ENABLE_FAILED_PAYMENT_CALLS=0
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+15551234567
# Required for failed-payment voice calls: public MP3/WAV URL Twilio <Play>s (no TTS fallback).
# TWILIO_FAILED_PAYMENT_AUDIO_URL=https://example.com/audio/failed-payment.mp3
# Voice playback speed: default is fastest (no AMD). For voicemail-after-beep, set DetectMessageEnd (adds delay).
# TWILIO_AMD_MODE=DetectMessageEnd   — answering-machine detection (slower human pickup; better voicemail)
# TWILIO_AMD_MODE=off                — default; play MP3 as soon as call connects
# If using DetectMessageEnd, Async AMD (default on) reduces silence; TWILIO_AMD_ASYNC=0 = fully synchronous.
# TWILIO_AMD_ASYNC=0
# TWILIO_AMD_STATUS_CALLBACK_URL=  — optional; Twilio POSTs AnsweredBy + CallSid when using Async AMD
# TWILIO_AMD_SPEECH_END_THRESHOLD_MS=800   — optional 500–5000 (only when AMD on)
# TWILIO_AMD_SPEECH_THRESHOLD_MS=2000      — optional 1000–6000 (only when AMD on)
# TWILIO_MACHINE_DETECTION_TIMEOUT=45  — optional seconds 3–59 (only when AMD on)
# Optional: extra E.164 numbers (comma-separated) to never call for failed-payment webhooks.
# Built-in blocklist always includes the internal work line; add more here if needed.
# TWILIO_FAILED_PAYMENT_BLOCKLIST=+15551234567,+442071838750
